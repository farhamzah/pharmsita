PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173
DB_ADAPTER=json
DATABASE_FILE=backend/.data/pharmsita-db.json
DATABASE_URL=
DATABASE_SSL=false
DATABASE_POOL_MAX=10
AUTH_SECRET=change-this-secret-before-production
