# Install as /etc/pharmsita/backend.env.
# Keep this file outside Git on the VPS and restrict permission to 0640.

NODE_ENV=production
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=https://pharmsita.example.ac.id

# Production must use PostgreSQL.
DB_ADAPTER=postgres
DATABASE_URL=postgres://pharmsita_user:change-this-password@127.0.0.1:5432/pharmsita
DATABASE_SSL=false
DATABASE_POOL_MAX=10
MIGRATION_ADVISORY_LOCK_KEY=810098

# Generate a unique long secret per environment.
AUTH_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800

# Keep scheduler off until the cleanup runbook has been approved.
AUDIT_EXPORT_CLEANUP_ENABLED=false
AUDIT_EXPORT_CLEANUP_INTERVAL_SECONDS=86400
AUDIT_EXPORT_ALLOWED_RETENTION_DAYS=30
AUDIT_EXPORT_BLOCKED_RETENTION_DAYS=90
AUDIT_EXPORT_CLEANUP_BATCH_SIZE=1000
AUDIT_EXPORT_CLEANUP_ADVISORY_LOCK_KEY=810081
