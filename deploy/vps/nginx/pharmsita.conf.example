# PharmSITA Nginx template.
# Install as /etc/nginx/conf.d/pharmsita.conf and replace pharmsita.example.ac.id.

map $http_x_request_id $pharmsita_request_id {
    "~^[a-zA-Z0-9._:-]{8,128}$" $http_x_request_id;
    default $request_id;
}

log_format pharmsita_main
    '$remote_addr - $remote_user [$time_local] "$request" $status $body_bytes_sent '
    '"$http_referer" "$http_user_agent" '
    'request_id="$pharmsita_request_id" upstream="$upstream_addr" '
    'upstream_status="$upstream_status" request_time="$request_time"';

upstream pharmsita_backend {
    server 127.0.0.1:4000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name pharmsita.example.ac.id;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name pharmsita.example.ac.id;

    root /var/www/pharmsita/current/dist;
    index index.html;

    access_log /var/log/nginx/pharmsita_access.log pharmsita_main;
    error_log /var/log/nginx/pharmsita_error.log warn;

    ssl_certificate /etc/letsencrypt/live/pharmsita.example.ac.id/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/pharmsita.example.ac.id/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:pharmsita_ssl:10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    client_max_body_size 25m;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    location = /api/v1/health {
        proxy_pass http://pharmsita_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Request-Id $pharmsita_request_id;
        proxy_set_header Connection "";
        proxy_hide_header X-Request-Id;
        add_header X-Request-Id $pharmsita_request_id always;
    }

    location = /api/v1 {
        proxy_pass http://pharmsita_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Request-Id $pharmsita_request_id;
        proxy_set_header Connection "";
        proxy_hide_header X-Request-Id;
        add_header X-Request-Id $pharmsita_request_id always;
    }

    location ^~ /api/v1/ {
        proxy_pass http://pharmsita_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Request-Id $pharmsita_request_id;
        proxy_set_header Connection "";
        proxy_connect_timeout 5s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        proxy_hide_header X-Request-Id;
        add_header X-Request-Id $pharmsita_request_id always;
    }

    location /assets/ {
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
